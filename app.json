{
  "expo": {
    "name": "AgroGuard X",
    "slug": "agroguard-x",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/agroguardx.jpeg",
    "scheme": "agroguardx",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/agroguardx.jpeg"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/agroguardx.jpeg",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "splash": {
      "image": "./assets/images/agroguardx.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#208AEF"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/agroguardx.jpeg",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
